  "client_config": {
    "platforms": ["Mac", "Windows", "Linux"],
    "sync_methods": {
      "webdav": {
        "urls": {
          "raywonderis": "https://files.raywonderis.me/dav/",
          "devinecreations": "https://files.devinecreations.net/dav/",
          "tappedin": "https://files.tappedin.fm/dav/",
          "tetoeehoward": "https://files.tetoeehoward.com/dav/",
          "walterharper": "https://files.walterharper.com/dav/",
          "local": "http://127.0.0.1:8081/dav/"
        },
        "description": "WebDAV mount for file system integration"
      },
      "rsync": {
        "enabled": true,
        "ssh_support": true,
        "description": "Rsync for efficient incremental sync"
      },
      "rest_api": {
        "urls": {
          "raywonderis": "https://files.raywonderis.me/api/",
          "devinecreations": "https://files.devinecreations.net/api/",
          "tappedin": "https://files.tappedin.fm/api/",
