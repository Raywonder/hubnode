          "local": "http://127.0.0.1:8081/api/"
        },
        "description": "REST API for programmatic access"
      }
    },
    "real_time_features": {
      "file_watching": true,
      "instant_upload": true,
      "conflict_resolution": "server_wins",
      "notifications": true,
      "progress_tracking": true
    }
  },
  "monitoring": {
    "log_location": "/var/log/copyparty-sync.log",
    "metrics_endpoint": "http://64.20.46.178:3923/metrics",
    "health_checks": true,
    "alerts": {
      "sync_failures": true,
      "connection_issues": true,
      "space_warnings": true
    }
  },
  "automation": {
    "auto_restart": true,
    "backup_on_change": false,
    "compress_transfers": true,
    "bandwidth_limiting": false,
    "scheduling": {
      "full_sync": "daily at 2:00 AM",
      "incremental": "continuous"
    }
  }
